<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/fragment_chinh_ta.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- ===== TOOLBAR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="16dp">

        <!-- Nút X -->
        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_close"
            android:background="@drawable/bg_btn_circle_gray"
            android:contentDescription="close" />

        <!-- Title + progress -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRINCESS MONONOKE | Official..."
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0% hoàn thành"
                android:textSize="12sp"
                android:textColor="#888888" />

        </LinearLayout>

        <!-- Timer badge -->
        <LinearLayout
            android:id="@+id/badgeTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_badge_timer"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_clock_circle"
                android:layout_marginEnd="4dp"
                android:contentDescription="timer" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:06"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#2196F3" />

        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE" />

    <!-- ===== SCROLL CONTENT ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- YouTube WebView -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="210dp">

                <WebView
                    android:id="@+id/webViewYoutube"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

            </FrameLayout>

            <!-- Controls row: Dừng tự động / speed / settings / list -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dừng tự động"
                    android:textSize="13sp"
                    android:textColor="#1A1A1A"
                    android:layout_marginEnd="8dp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAutoStop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <!-- Speed button -->
                <LinearLayout
                    android:id="@+id/btnSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_pill_gray"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_speed"
                        android:layout_marginEnd="4dp"
                        android:contentDescription="speed" />

                    <TextView
                        android:id="@+id/tvSpeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.0x"
                        android:textSize="13sp"
                        android:textColor="#1A1A1A" />

                </LinearLayout>

                <!-- Settings -->
                <ImageButton
                    android:id="@+id/btnSettings"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_settings"
                    android:background="@drawable/bg_btn_circle_gray"
                    android:contentDescription="settings"
                    android:layout_marginEnd="8dp" />

                <!-- List/transcript -->
                <ImageButton
                    android:id="@+id/btnTranscript"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_list"
                    android:background="@drawable/bg_btn_circle_gray"
                    android:contentDescription="transcript" />

            </LinearLayout>

            <!-- ===== SENTENCE SELECTOR (số câu) ===== -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/llSentenceNumbers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Câu 1 (active - xanh) -->
                    <TextView
                        android:id="@+id/tvSentence1"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="1"
                        android:gravity="center"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:background="@drawable/bg_sentence_active"
                        android:layout_marginEnd="8dp" />

                    <!-- Câu 2-5 (chưa chọn) -->
                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="2"
                        android:gravity="center"
                        android:textSize="15sp"
                        android:textColor="#1A1A1A"
                        android:background="@drawable/bg_sentence_normal"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="3"
                        android:gravity="center"
                        android:textSize="15sp"
                        android:textColor="#1A1A1A"
                        android:background="@drawable/bg_sentence_normal"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="4"
                        android:gravity="center"
                        android:textSize="15sp"
                        android:textColor="#1A1A1A"
                        android:background="@drawable/bg_sentence_normal"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="5"
                        android:gravity="center"
                        android:textSize="15sp"
                        android:textColor="#1A1A1A"
                        android:background="@drawable/bg_sentence_normal"
                        android:layout_marginEnd="8dp" />

                    <!-- Câu 6-7 (PRO - unlock hết) -->
                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="6"
                        android:gravity="center"
                        android:textSize="15sp"
                        android:textColor="#1A1A1A"
                        android:background="@drawable/bg_sentence_normal"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="7"
                        android:gravity="center"
                        android:textSize="15sp"
                        android:textColor="#1A1A1A"
                        android:background="@drawable/bg_sentence_normal"
                        android:layout_marginEnd="8dp" />

                </LinearLayout>

            </HorizontalScrollView>

            <!-- ===== WORD CARDS (câu bị ẩn) ===== -->
            <androidx.cardview.widget.CardView
                xmlns:app2="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                app2:cardCornerRadius="16dp"
                app2:cardElevation="0dp"
                app2:cardBackgroundColor="#F5F5F5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Play + Replay + Bookmark + Flag -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageButton
                            android:id="@+id/btnPlaySentence"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_play_filled"
                            android:background="@drawable/bg_btn_play_blue"
                            android:contentDescription="play sentence"
                            android:layout_marginEnd="8dp" />

                        <ImageButton
                            android:id="@+id/btnReplay"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_replay"
                            android:background="@drawable/bg_btn_circle_gray"
                            android:contentDescription="replay" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1" />

                        <ImageButton
                            android:id="@+id/btnBookmark"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_bookmark"
                            android:background="@android:color/transparent"
                            android:contentDescription="bookmark"
                            android:layout_marginEnd="4dp" />

                        <ImageButton
                            android:id="@+id/btnFlag"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_flag"
                            android:background="@android:color/transparent"
                            android:contentDescription="flag" />

                    </LinearLayout>

                    <!-- Các từ bị ẩn (dots) - dòng 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="···"
                            android:background="@drawable/bg_word_hidden"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:textColor="#999999"
                            android:textSize="14sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="·······"
                            android:background="@drawable/bg_word_hidden"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:textColor="#999999"
                            android:textSize="14sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="···"
                            android:background="@drawable/bg_word_hidden"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:textColor="#999999"
                            android:textSize="14sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="····"
                            android:background="@drawable/bg_word_hidden"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:textColor="#999999"
                            android:textSize="14sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="·········"
                            android:background="@drawable/bg_word_hidden"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:textColor="#999999"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <!-- Dòng 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="··"
                            android:background="@drawable/bg_word_hidden"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:textColor="#999999"
                            android:textSize="14sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="·····"
                            android:background="@drawable/bg_word_hidden"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:textColor="#999999"
                            android:textSize="14sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="····"
                            android:background="@drawable/bg_word_hidden"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:textColor="#999999"
                            android:textSize="14sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="····"
                            android:background="@drawable/bg_word_hidden"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:textColor="#999999"
                            android:textSize="14sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="···"
                            android:background="@drawable/bg_word_hidden"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:textColor="#999999"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <!-- Dòng 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="······"
                            android:background="@drawable/bg_word_hidden"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:textColor="#999999"
                            android:textSize="14sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="····"
                            android:background="@drawable/bg_word_hidden"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:textColor="#999999"
                            android:textSize="14sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="·········"
                            android:background="@drawable/bg_word_hidden"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:textColor="#999999"
                            android:textSize="14sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="···"
                            android:background="@drawable/bg_word_hidden"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:textColor="#999999"
                            android:textSize="14sp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ===== INPUT ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gõ những gì bạn nghe được:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etInput"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_box"
                android:padding="12dp"
                android:gravity="top"
                android:hint=""
                android:inputType="textMultiLine"
                android:textSize="14sp"
                android:textColor="#1A1A1A" />

        </LinearLayout>

    </ScrollView>

    <!-- ===== BOTTOM BUTTON ===== -->
    <Button
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:layout_marginTop="8dp"
        android:text="Bắt đầu"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:background="@drawable/bg_btn_primary"
        android:stateListAnimator="@null" />

</LinearLayout>