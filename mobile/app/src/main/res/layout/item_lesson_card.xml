<?xml version="1.0" encoding="utf-8"?>
<!--
    item_lesson_card.xml
    Template tái sử dụng cho mỗi bài học trong HorizontalScrollView.
    Dùng <include layout="@layout/item_lesson_card" /> hoặc inflate trong Adapter.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginEnd="12dp"
    android:background="@drawable/bg_card_white"
    android:elevation="2dp">

    <!-- Thumbnail + Badge overlay -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="120dp">

        <!-- Thumbnail -->
        <ImageView
            android:id="@+id/imgThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/img_placeholder_thumbnail"
            android:contentDescription="Thumbnail" />

        <!-- Level badge (A2 / B1 ...) - top left -->
        <TextView
            android:id="@+id/tvLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="8dp"
            android:text="A2"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:background="@drawable/bg_badge_green" />

        <!-- PRO badge - top right (ẩn nếu không phải PRO) -->
        <TextView
            android:id="@+id/tvPro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:text="👑 PRO"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:background="@drawable/bg_badge_orange"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Meta: duration + views -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingTop="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="▶ 01:04"
            android:textSize="11sp"
            android:textColor="#8E8E93" />

        <TextView
            android:id="@+id/tvViews"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👁 26.1K"
            android:textSize="11sp"
            android:textColor="#8E8E93" />
    </LinearLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="10dp"
        android:paddingTop="4dp"
        android:text="PRINCESS MONONOKE | Official English Trailer"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- Exercise chips: Chính tả, Luyện nói -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/chipDictation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○  Chính tả"
            android:textSize="11sp"
            android:textColor="#8E8E93"
            android:background="@drawable/bg_chip"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/chipSpeaking"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○  Luyện nói"
            android:textSize="11sp"
            android:textColor="#8E8E93"
            android:background="@drawable/bg_chip"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp" />

    </LinearLayout>

</LinearLayout>